#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-push checks..."

# Test build before allowing push
echo "📦 Testing production build..."
npm run build

if [ $? -ne 0 ]; then
  echo "❌ Build failed! Fix errors before pushing."
  exit 1
fi

echo "✅ Build successful! Proceeding with push..."
exit 0
